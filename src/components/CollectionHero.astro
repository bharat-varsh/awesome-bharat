---
export interface StatPill {
    label: string;
    href?: string;
}

export interface Props {
    eyebrow?: string;
    title: string;
    description: string;
    countLabel: string;
    icon?: string;
    pills?: StatPill[];
}

const { eyebrow, title, description, countLabel, icon = '#', pills = [] } = Astro.props;
---

<section
    class="overflow-hidden rounded-lg border border-primary-200/80 bg-gradient-to-br from-primary-100 via-white to-secondary-100 px-5 py-6 shadow-sm dark:border-secondary-700 dark:from-secondary-800 dark:via-secondary-900 dark:to-gray-900 sm:px-7 sm:py-8"
>
    <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0">
            {
                eyebrow && (
                    <p class="mb-3 text-xs font-semibold uppercase tracking-wide text-primary-700 dark:text-primary-300">
                        {eyebrow}
                    </p>
                )
            }
            <div class="flex items-center gap-3">
                <span
                    class="grid h-12 w-12 flex-none place-items-center rounded-lg bg-white text-2xl shadow-sm ring-1 ring-primary-200 dark:bg-secondary-800 dark:ring-secondary-700"
                    aria-hidden="true"
                >
                    {icon}
                </span>
                <h1
                    class="break-words font-display text-3xl font-extrabold leading-tight text-gray-950 dark:text-white sm:text-4xl"
                >
                    {title}
                </h1>
            </div>
            <p class="mt-4 max-w-2xl text-base leading-7 text-gray-700 dark:text-gray-300">
                {description}
            </p>
        </div>

        <p
            class="w-fit flex-none rounded-full bg-primary-600 px-4 py-2 text-sm font-semibold text-white shadow-sm"
        >
            {countLabel}
        </p>
    </div>

    {
        pills.length > 0 && (
            <nav class="mt-6 flex gap-2 overflow-x-auto pb-1" aria-label="Page sections">
                {pills.map((pill) =>
                    pill.href ? (
                        <a
                            href={pill.href}
                            class="whitespace-nowrap rounded-full bg-white/90 px-3 py-1.5 text-sm font-semibold text-gray-800 ring-1 ring-primary-200 transition hover:bg-primary-600 hover:text-white dark:bg-secondary-800 dark:text-gray-100 dark:ring-secondary-700"
                        >
                            {pill.label}
                        </a>
                    ) : (
                        <span class="whitespace-nowrap rounded-full bg-white/90 px-3 py-1.5 text-sm font-semibold text-gray-800 ring-1 ring-primary-200 dark:bg-secondary-800 dark:text-gray-100 dark:ring-secondary-700">
                            {pill.label}
                        </span>
                    )
                )}
            </nav>
        )
    }
</section>
