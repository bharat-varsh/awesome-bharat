---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import type { Link } from '@/content/config.ts';
import Divider from '@/components/Divider.astro';
import addIcon from '@/assets/images/engage/add.svg';
import bugIcon from '@/assets/images/engage/bug.svg';
import fixIcon from '@/assets/images/engage/fix.svg';
import suggestIcon from '@/assets/images/engage/suggest.svg';
import defaultImage from '@/assets/images/engage/default.svg';
import instagram from '@/assets/images/engage/instagram.svg';
import reddit from '@/assets/images/engage/reddit.svg';
import telegram from '@/assets/images/engage/telegram.svg';
import websiteLink from '@/assets/images/engage/website.svg';

interface Props {
    source: string;
    repositoryLinks?: { label: string; url: string }[];
    socials?: { label: string; url: string }[];
    website?: string;
}

const { repositoryLinks, source, socials, website } = Astro.props;

// Social platforms to logo mapping
const socialIconMap: Record<string, ImageMetadata> = {
    bluesky: defaultImage,
    discord: defaultImage,
    instagram,
    reddit,
    telegram,
    x: defaultImage,
    __DEFAULT: defaultImage,
};

const gitHubUrl = repositoryLinks?.find((link: Link) => link.label.toLowerCase() === 'github')?.url;

const normalizeSocialLabel = (label: string): string => label.toLowerCase();

// Contribution actions for open-source projects
const contributionActions = gitHubUrl
    ? [
          {
              icon: addIcon,
              label: 'Add a feature',
              description: 'Pick up a feature request',
              url: `${gitHubUrl}/issues?q=is%3Aissue%20state%3Aopen%20(no%3Alabel%20OR%20label%3Adocumentation%20OR%20label%3Aenhancement%20OR%20label%3A%22good%20first%20issue%22%20OR%20label%3A%22help%20wanted%22%20OR%20label%3A%22high%20priority%22)`,
          },
          {
              icon: fixIcon,
              label: 'Fix a bug',
              description: 'Find issues to resolve',
              url: `${gitHubUrl}/issues?q=is%3Aissue%20state%3Aopen%20(no%3Alabel%20OR%20label%3Abug)`,
          },
          {
              icon: suggestIcon,
              label: 'Suggest something',
              description: 'Request a new feature',
              url: `${gitHubUrl}/issues/new?template=feature_request.md`,
          },
          {
              icon: bugIcon,
              label: 'Report a bug',
              description: 'Submit a bug report',
              url: `${gitHubUrl}/issues/new?template=bug_report.md`,
          },
      ]
    : [];
---

<>
    {(source === 'open-source' || socials || website) && <Divider />}

    <div class="space-y-6">
        <!-- Contribute to development (Open source only) -->
        {
            source === 'open-source' && contributionActions.length > 0 && (
                <section>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-3">
                        Contribute to development
                    </h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                        {contributionActions.map((action) => (
                            <a
                                href={action.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex flex-col items-start p-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary-500 dark:hover:border-primary-400 hover:shadow-md transition-all duration-200 bg-white dark:bg-gray-800"
                            >
                                <Image
                                    class="w-5 h-5 mb-2 text-primary-600 dark:text-primary-400"
                                    src={action.icon}
                                    alt={action.label}
                                    format="webp"
                                    widths={[140, 160, 180, 200, 220]}
                                    sizes="(min-width:1024px) 200px, (min-width:640px) 180px, 160px"
                                />
                                <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
                                    {action.label}
                                </span>
                                <span class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">
                                    {action.description}
                                </span>
                            </a>
                        ))}
                    </div>
                </section>
            )
        }

        <!-- On the web (Website + Socials) -->
        {
            (website || (socials && socials.length > 0)) && (
                <section>
                    <h3 class="text-base font-semibold text-gray-900 dark:text-gray-100 mb-3">
                        On the web
                    </h3>
                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
                        {/* Website */}
                        {website && (
                            <a
                                href={website}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="flex flex-col items-start p-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary-500 dark:hover:border-primary-400 hover:shadow-md transition-all duration-200 bg-white dark:bg-gray-800"
                            >
                                <Image
                                    class="w-5 h-5 mb-2 text-primary-600 dark:text-primary-400"
                                    src={websiteLink}
                                    alt="Website"
                                    format="webp"
                                    widths={[140, 160, 180, 200, 220]}
                                    sizes="(min-width:1024px) 200px, (min-width:640px) 180px, 160px"
                                />
                                <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
                                    Website
                                </span>
                                <span class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">
                                    Visit official site
                                </span>
                            </a>
                        )}

                        {/* Socials */}
                        {socials &&
                            socials.map((social: Link) => {
                                const iconKey = normalizeSocialLabel(social.label);
                                const iconPath =
                                    socialIconMap[iconKey] || socialIconMap['__DEFAULT'];

                                return (
                                    <a
                                        href={social.url}
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        class="flex flex-col items-start p-3 rounded-lg border border-gray-200 dark:border-gray-700 hover:border-primary-500 dark:hover:border-primary-400 hover:shadow-md transition-all duration-200 bg-white dark:bg-gray-800"
                                    >
                                        <Image
                                            class="w-5 h-5 mb-2 text-primary-600 dark:text-primary-400"
                                            src={iconPath}
                                            alt={social.label}
                                            format="webp"
                                            widths={[140, 160, 180, 200, 220]}
                                            sizes="(min-width:1024px) 200px, (min-width:640px) 180px, 160px"
                                        />
                                        <span class="text-sm font-medium text-gray-900 dark:text-gray-100">
                                            {social.label}
                                        </span>
                                        <span class="text-xs text-gray-500 dark:text-gray-400 line-clamp-1">
                                            Follow on {social.label}
                                        </span>
                                    </a>
                                );
                            })}
                    </div>
                </section>
            )
        }
    </div>

    {(source === 'open-source' || socials || website) && <Divider />}
</>
