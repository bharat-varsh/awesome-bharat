---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { resolveLogo } from '@/utils/imageResolvers.ts';

export interface Props {
    title: string;
    href: string;
    slug: string;
    image?: string;
    description?: string;
    tags?: string[];
    ctaLabel?: string;
    badge?: string;
}

const { title, href, slug, image, description, tags = [], ctaLabel = 'View', badge } = Astro.props;
const resolvedImage = resolveLogo(slug, image) as ImageMetadata;
const primaryTag = tags[0];
---

<a
    href={href}
    class="group flex h-full min-w-[240px] flex-col rounded-lg border border-gray-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-primary-300 hover:shadow-md dark:border-secondary-700 dark:bg-secondary-800 dark:hover:border-primary-400 sm:min-w-[280px]"
>
    <div class="flex items-start gap-4">
        <div
            class="grid h-16 w-16 flex-none place-items-center overflow-hidden rounded-lg bg-gray-50 ring-1 ring-gray-100 dark:bg-secondary-900 dark:ring-secondary-700"
        >
            <Image
                class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
                src={resolvedImage}
                alt={title}
                format="webp"
                widths={[64, 96, 128]}
                sizes="64px"
            />
        </div>

        <div class="min-w-0 flex-1">
            <div class="flex items-start justify-between gap-2">
                <h2
                    class="line-clamp-2 text-base font-bold leading-snug text-gray-950 dark:text-white"
                >
                    {title}
                </h2>
                {
                    badge && (
                        <span class="flex-none rounded-full bg-secondary-100 px-2 py-0.5 text-xs font-semibold text-secondary-800 dark:bg-secondary-700 dark:text-secondary-50">
                            {badge}
                        </span>
                    )
                }
            </div>
            {
                primaryTag && (
                    <span class="mt-2 inline-flex rounded-full bg-primary-50 px-2 py-1 text-xs font-semibold text-primary-700 dark:bg-primary-900/50 dark:text-primary-200">
                        #{primaryTag}
                    </span>
                )
            }
        </div>
    </div>

    {
        description && (
            <p class="mt-4 line-clamp-2 text-sm leading-6 text-gray-600 dark:text-gray-300">
                {description}
            </p>
        )
    }

    <span
        class="mt-auto pt-4 text-sm font-semibold text-primary-700 transition group-hover:text-primary-800 dark:text-primary-300 dark:group-hover:text-primary-200"
    >
        {ctaLabel}
    </span>
</a>
