---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { resolveLogo } from '@/utils/imageResolvers.ts';
import { formatCategoryName } from '@/utils/textUtils.ts';

export interface Props {
    title: string;
    description?: string;
    slug: string;
    collection: string; // 'apps' | 'persons' | 'companies' | etc.
    logoSrc?: ImageMetadata;
    domains?: string[];
    categories?: string[];
    ctaLabel?: string | null;
    ctaUrl?: string | null;
    featured?: boolean;
}

const {
    title,
    description,
    slug,
    collection,
    logoSrc,
    domains = [],
    categories = [],
    ctaLabel = null,
    ctaUrl = null,
    featured = false,
} = Astro.props;
const resolvedLogo = logoSrc ?? resolveLogo(slug);
const primaryDomain = domains[0];
const primaryCategory = categories[0];
const showDomainBadge = !!primaryDomain;
const showCategoryBadge = !!primaryCategory && !showDomainBadge; // Only show one badge max
---

<a
    href={`/${collection}/${slug}`}
    class={`group block min-w-[280px] rounded-xl border p-4 transition-all duration-200 hover:-translate-y-[2px] hover:shadow-md ${
        featured ? 'border-yellow-400' : 'border-gray-200 dark:border-secondary-600'
    } bg-white dark:bg-secondary-800`}
>
    <div class="flex gap-4">
        <div class="flex-shrink-0">
            <div
                class="h-14 w-14 overflow-hidden rounded-lg bg-gray-50 ring-1 ring-gray-200 dark:bg-secondary-900 dark:ring-secondary-700"
            >
                <Image
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                    src={resolvedLogo}
                    alt={title}
                    format="webp"
                    widths={[56, 96, 128]}
                    sizes="56px"
                />
            </div>
        </div>

        <div class="min-w-0 flex-1">
            <div class="flex items-start justify-between">
                <h2
                    class="line-clamp-2 text-base font-semibold leading-snug text-gray-900 dark:text-white"
                >
                    {title}
                </h2>
                {
                    featured && (
                        <span class="flex-shrink-0 rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-semibold text-yellow-800 dark:bg-yellow-900 dark:text-yellow-200">
                            ★ Featured
                        </span>
                    )
                }
            </div>

            {
                description && (
                    <p class="mt-2 line-clamp-2 text-sm leading-6 text-gray-600 dark:text-gray-400">
                        {description}
                    </p>
                )
            }

            <div class="mt-3 flex flex-wrap gap-2">
                {
                    showDomainBadge && (
                        <span class="inline-flex items-center rounded-full bg-primary-100 px-2 py-1 text-xs font-medium text-primary-800 dark:bg-primary-900 dark:text-primary-200">
                            {primaryDomain}
                        </span>
                    )
                }
                {
                    showCategoryBadge && (
                        <span class="inline-flex items-center rounded-full bg-secondary-100 px-2 py-1 text-xs font-medium text-secondary-800 dark:bg-secondary-700 dark:text-secondary-200">
                            {formatCategoryName(primaryCategory)}
                        </span>
                    )
                }
            </div>

            {
                ctaLabel && ctaUrl && (
                    <span class="mt-3 inline-flex items-center text-sm font-medium text-primary-500 transition group-hover:text-primary-600 dark:text-primary-400 dark:group-hover:text-primary-300">
                        {ctaLabel}
                        <svg
                            class="ml-1 h-4 w-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M9 5l7 7-7 7"
                            />
                        </svg>
                    </span>
                )
            }
        </div>
    </div>
</a>
