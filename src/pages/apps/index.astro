---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCardFull from '@/components/ContentCardFull.astro';
import CollectionHero from '@/components/CollectionHero.astro';
import { getPrimaryCTALabel, getPrimaryCTAUrl } from '@/utils/ctaUtils.ts';
import { resolveLogo } from '@/utils/imageResolvers.ts';

const apps = (await getCollection('apps')) as Array<CollectionEntry<'apps'>>;
const visibleApps = apps
    .filter((app) => !app.data.draft)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
    title="Apps | Awesome Bharat"
    description="Amazing apps made by Indians, with love, for the globe"
>
    <div class="max-w-7xl mx-auto px-4 py-10 sm:px-6 lg:px-8">
        <div class="mb-10">
            <CollectionHero
                title="Apps"
                description="Amazing apps made by Indians, with love, for the globe"
                countLabel={`${visibleApps.length} apps`}
                icon="📱"
                eyebrow="Collection"
            />
        </div>

        <div class="grid
        grid-cols-[repeat(auto-fit,minmax(280px,1fr))]
        gap-6">
            {
                visibleApps.map((app) => {
                    const ctaLabel = 'View More';
                    const ctaUrl = getPrimaryCTAUrl('apps', app.data);

                    return (
                        <ContentCardFull
                            title={app.data.title}
                            description={app.data.description}
                            slug={app.slug}
                            collection="apps"
                            logoSrc={
                                app.data.logo ? resolveLogo(app.slug, app.data.logo) : undefined
                            }
                            domains={app.data.tags
                                ?.filter((tag: string) => tag.startsWith('domain:'))
                                ?.map((tag: string) => tag.replace('domain:', ''))}
                            categories={app.data.categories}
                            ctaLabel={ctaLabel}
                            ctaUrl={ctaUrl}
                            featured={app.data.featured}
                        />
                    );
                })
            }
        </div>
    </div>
</BaseLayout>
