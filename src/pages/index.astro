---
/**
 * Homepage – Main landing page
 */

import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ContentCard from '@/components/ContentCard.astro';

const [apps, persons, companies] = await Promise.all([
    getCollection('apps'),
    getCollection('persons'),
    getCollection('companies'),
]);

const nonDraftApps = apps.filter((app: CollectionEntry<'apps'>) => !app.data.draft);
const nonDraftPersons = persons.filter((p: CollectionEntry<'persons'>) => !p.data.draft);
const nonDraftCompanies = companies.filter((c: CollectionEntry<'companies'>) => !c.data.draft);

const stats = {
    apps: nonDraftApps.length,
    persons: nonDraftPersons.length,
    companies: nonDraftCompanies.length,
};

const latestApps = [...nonDraftApps]
    .sort(
        (a: CollectionEntry<'apps'>, b: CollectionEntry<'apps'>) =>
            b.data.date.valueOf() - a.data.date.valueOf()
    )
    .slice(0, 20);

const featuredPersons = [...nonDraftPersons]
    .sort(
        (a: CollectionEntry<'persons'>, b: CollectionEntry<'persons'>) =>
            (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0)
    )
    .slice(0, 20);

const featuredCompanies = [...nonDraftCompanies]
    .sort(
        (a: CollectionEntry<'companies'>, b: CollectionEntry<'companies'>) =>
            (b.data.featured ? 1 : 0) - (a.data.featured ? 1 : 0)
    )
    .slice(0, 20);

const allCategories = [
    ...new Set(nonDraftApps.flatMap((app: CollectionEntry<'apps'>) => app.data.categories)),
].sort() as string[];

function formatCategory(category: string) {
    return category
        .replace(/([A-Z])/g, ' $1')
        .replace(/^./, (str) => str.toUpperCase())
        .trim();
}
---

<BaseLayout
    title="Home | Awesome Bharat"
    description="A curated collection of awesome made by Indians! Discover your inspiration and the great people who made that possible!"
>
    <!-- Hero -->
    <section class="py-12 relative overflow-hidden">
        <!-- Background gradient -->
        <div
            class="absolute inset-0 bg-gradient-to-b from-primary-100 via-primary-50/50 to-transparent dark:from-secondary-900 dark:via-secondary-800/50 dark:to-transparent"
        >
        </div>

        <div class="max-w-7xl mx-auto px-4 text-center relative">
            <h1 class="font-bold tracking-tight mb-6">
                <!-- Desktop -->
                <span class="hidden md:block text-5xl lg:text-6xl text-gray-900 dark:text-gray-100">
                    Welcome to
                    <span class="text-primary-600 dark:text-primary-400"> Awesome</span>
                    <span class="font-extrabold"> Bharat</span>
                </span>

                <!-- Mobile -->
                <span
                    class="block md:hidden text-4xl lg:text-5xl leading-tight text-gray-900 dark:text-gray-100"
                >
                    <span class="block">Welcome to</span>
                    <span class="block text-primary-600 dark:text-primary-400">Awesome</span>
                    <span class="block font-extrabold">Bharat</span>
                </span>
            </h1>

            <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl mx-auto mb-8">
                A curated collection of awesome made by Indians! Discover your inspiration and the
                great people who made that possible!
            </p>

            <!-- Stat strip -->
            <div
                class="inline-flex flex-wrap items-center justify-center gap-4 text-sm font-medium text-gray-700 dark:text-gray-300"
            >
                <span class="flex items-center gap-1.5">
                    <span class="text-primary-600 dark:text-primary-400 font-bold text-lg"
                        >{stats.apps}</span
                    >
                    apps
                </span>
                <span class="w-1 h-1 rounded-full bg-gray-400 dark:bg-gray-600"></span>
                <span class="flex items-center gap-1.5">
                    <span class="text-primary-600 dark:text-primary-400 font-bold text-lg"
                        >{stats.persons}</span
                    >
                    people
                </span>
                <span class="w-1 h-1 rounded-full bg-gray-400 dark:bg-gray-600"></span>
                <span class="flex items-center gap-1.5">
                    <span class="text-primary-600 dark:text-primary-400 font-bold text-lg"
                        >{stats.companies}</span
                    >
                    companies
                </span>
                <span class="w-1 h-1 rounded-full bg-gray-400 dark:bg-gray-600"></span>
                <span class="text-primary-600 dark:text-primary-400">all Indian-made</span>
            </div>
        </div>
    </section>

    <div class="max-w-7xl mx-auto px-4 py-12 space-y-12">
        <!-- Latest Apps -->
        <section class="space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">Latest Apps</h2>
                <a href="/apps" class="text-sm text-primary-500 hover:text-primary-600">View all</a>
            </div>

            <!-- Horizontal scroll row -->
            <div class="relative">
                <!-- Left arrow -->
                <button
                    aria-label="Scroll left"
                    class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 z-10
                 h-9 w-9 rounded-full bg-gray-900/70 hover:bg-gray-900
                 text-white items-center justify-center scroll-left"
                    data-scroll-container="latest-apps"
                >
                    ‹
                </button>

                <!-- Scroll container -->
                <div
                    id="latest-apps"
                    class="flex gap-5 overflow-x-auto scroll-smooth pb-2
                 snap-x snap-mandatory
                 px-10 md:px-12 scrollbar-hide"
                >
                    {
                        latestApps.map((app) => (
                            <ContentCard
                                title={app.data.title}
                                href={`/apps/${app.slug}`}
                                image={app.data.logo}
                                slug={app.slug}
                                tags={app.data.tags}
                                class="snap-start"
                            />
                        ))
                    }
                </div>

                <!-- Right arrow -->
                <button
                    aria-label="Scroll right"
                    class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 z-10
                 h-9 w-9 rounded-full bg-gray-900/70 hover:bg-gray-900
                 text-white items-center justify-center scroll-right"
                    data-scroll-container="latest-apps"
                >
                    ›
                </button>
            </div>
        </section>

        <!-- Featured People -->
        <section class="space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
                    Featured People
                </h2>
                <a href="/people" class="text-sm text-primary-500 hover:text-primary-600"
                    >View all</a
                >
            </div>

            <!-- Horizontal scroll row -->
            <div class="relative">
                <!-- Left arrow -->
                <button
                    aria-label="Scroll left"
                    class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 z-10
                 h-9 w-9 rounded-full bg-gray-900/70 hover:bg-gray-900
                 text-white items-center justify-center scroll-left"
                    data-scroll-container="featured-people"
                >
                    ‹
                </button>

                <!-- Scroll container -->
                <div
                    id="featured-people"
                    class="flex gap-5 overflow-x-auto scroll-smooth pb-2
                 snap-x snap-mandatory
                 px-10 md:px-12 scrollbar-hide"
                >
                    {
                        featuredPersons.map((person) => (
                            <ContentCard
                                title={person.data.name}
                                href={`/people/${person.slug}`}
                                image={person.data.avatar}
                                slug={person.slug}
                                tags={person.data.tags}
                                class="snap-start"
                            />
                        ))
                    }
                </div>

                <!-- Right arrow -->
                <button
                    aria-label="Scroll right"
                    class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 z-10
                 h-9 w-9 rounded-full bg-gray-900/70 hover:bg-gray-900
                 text-white items-center justify-center scroll-right"
                    data-scroll-container="featured-people"
                >
                    ›
                </button>
            </div>
        </section>

        <!-- Featured Companies -->
        <section class="space-y-4">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
                    Featured Companies
                </h2>
                <a href="/companies" class="text-sm text-primary-500 hover:text-primary-600"
                    >View all</a
                >
            </div>

            <!-- Horizontal scroll row -->
            <div class="relative">
                <!-- Left arrow -->
                <button
                    aria-label="Scroll left"
                    class="hidden md:flex absolute left-0 top-1/2 -translate-y-1/2 z-10
                 h-9 w-9 rounded-full bg-gray-900/70 hover:bg-gray-900
                 text-white items-center justify-center scroll-left"
                    data-scroll-container="featured-companies"
                >
                    ‹
                </button>

                <!-- Scroll container -->
                <div
                    id="featured-companies"
                    class="flex gap-5 overflow-x-auto scroll-smooth pb-2
                 snap-x snap-mandatory
                 px-10 md:px-12 scrollbar-hide"
                >
                    {
                        featuredCompanies.map((company) => (
                            <ContentCard
                                title={company.data.name}
                                href={`/companies/${company.slug}`}
                                image={company.data.logo}
                                slug={company.slug}
                                tags={company.data.tags}
                                class="snap-start"
                            />
                        ))
                    }
                </div>

                <!-- Right arrow -->
                <button
                    aria-label="Scroll right"
                    class="hidden md:flex absolute right-0 top-1/2 -translate-y-1/2 z-10
                 h-9 w-9 rounded-full bg-gray-900/70 hover:bg-gray-900
                 text-white items-center justify-center scroll-right"
                    data-scroll-container="featured-companies"
                >
                    ›
                </button>
            </div>
        </section>

        <!-- Explore by Category -->
        <section class="space-y-4">
            <h2 class="text-xl font-semibold text-gray-900 dark:text-gray-100">
                Explore by Category
            </h2>
            <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-6 gap-4">
                {
                    allCategories.map((category) => (
                        <a
                            href={`/categories/${category}`}
                            class="bg-white dark:bg-secondary-800 border border-gray-200 dark:border-secondary-700
                                 rounded-xl p-4 flex items-center justify-center text-center font-medium text-gray-700 dark:text-gray-200
                                 hover:bg-primary-50 dark:hover:bg-secondary-700 hover:border-primary-300 dark:hover:border-primary-500
                                 transition-all duration-200"
                        >
                            {formatCategory(category)}
                        </a>
                    ))
                }
            </div>
        </section>

        <!-- CTA -->
        <div class="pt-8 text-center">
            <a
                href="/apps"
                class="inline-block px-8 py-3 rounded-lg
             bg-primary-600 text-white font-medium
             hover:bg-primary-700 transition-colors"
            >
                Explore everything
            </a>
        </div>
    </div>

    <script>
        // Handle horizontal scroll with data attributes instead of fragile DOM traversal
        document.querySelectorAll('.scroll-left, .scroll-right').forEach((button) => {
            button.addEventListener('click', () => {
                const containerId = button.getAttribute('data-scroll-container');
                if (!containerId) return;
                const container = document.getElementById(containerId);
                if (container) {
                    const scrollAmount = 320;
                    const direction = button.classList.contains('scroll-left') ? -1 : 1;
                    container.scrollBy({
                        left: scrollAmount * direction,
                        behavior: 'smooth',
                    });
                }
            });
        });
    </script>
</BaseLayout>
