---
/** Layout for individual content pages (apps, products, companies, people, channels, etc) */

import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';
import RightSidebar from '../components/RightSidebar.astro';
import Screenshots from '../components/Screenshots.astro';
import Engage from '@/components/Engage.astro';
import YouTubeEmbed from '@/components/YouTubeEmbed.astro';
import StoreBadges from '@/components/StoreBadges.astro';
import { resolveLogo } from '../utils/imageResolvers.ts';
import { formatCategoryName } from '../utils/textUtils.ts';
import { getCTALinks, getPrimaryCTALabel, getPrimaryCTAUrl } from '../utils/ctaUtils.ts';
import googlePlayBadge from '../assets/images/badges/google-play-badge.png';
import appStoreBadge from '../assets/images/badges/app-store-badge.png';
import fdroidBadge from '../assets/images/badges/fdroid-badge.png';
import githubBadge from '../assets/images/badges/github-badge.png';

export interface Props {
    slug: string;
    collection: string;
    title: string;
    description: string;
    image?: string;
    date: Date;
    tags?: string[];
    categories: string[];
    paid: boolean;
    ads: boolean;
    offline: boolean;
    source: string;
    type?: string;
    youtubeVideoIds?: string[];
    youtubeShortsIds?: string[];
    externalLinks?: { label: string; url: string }[];
    storeLinks?: { label: string; url: string }[];
    repositoryLinks?: { label: string; url: string }[];
    screenshots?: Array<{ url: string }>;
    socials?: { label: string; url: string }[];
    website?: string;
    authors?: Array<CollectionEntry<'persons'>>;
}

const {
    slug,
    collection,
    title,
    description,
    image,
    date,
    tags,
    categories,
    paid,
    ads,
    offline,
    source,
    type,
    youtubeVideoIds,
    youtubeShortsIds,
    externalLinks,
    storeLinks,
    repositoryLinks,
    screenshots,
    socials,
    website,
    authors = [],
} = Astro.props;
const resolvedImage = resolveLogo(slug, image);

// Get first author for display
const primaryAuthor = authors.length > 0 ? authors[0] : null;
const authorLink = primaryAuthor ? `/${primaryAuthor.collection}/${primaryAuthor.slug}` : null;

// Compute CTA groups and primary button
const ctaGroups = getCTALinks(collection, { type, source, storeLinks, repositoryLinks, website });
const primaryCTALabel = getPrimaryCTALabel(collection, {
    type,
    source,
    storeLinks,
    repositoryLinks,
    website,
});
const primaryCTAUrl = getPrimaryCTAUrl(collection, {
    type,
    source,
    storeLinks,
    repositoryLinks,
    website,
});
---

<BaseLayout
    title={title}
    description={description}
    image={image}
    article={true}
    publishedTime={date.toISOString()}
    tags={tags}
>
    <div class="flex flex-col lg:flex-row gap-0 justify-center items-start">
        <article
            class="max-w-6xl px-10 py-8 lg:h-[calc(100vh-4rem)] lg:overflow-y-auto scrollbar-hide"
        >
            <header class="mb-12">
                <!-- Main header card with responsive layout -->
                <div
                    class="rounded-2xl shadow-lg shadow-primary-400/80 dark:shadow-primary-900/80 bg-white dark:bg-secondary-900 p-4 sm:p-6"
                >
                    <!-- Mobile: stacked, Tablet: 2-col, Desktop: 3-col -->
                    <div
                        class="grid grid-cols-1 md:grid-cols-[96px_1fr] lg:grid-cols-[96px_1fr_auto] gap-4 md:gap-6"
                    >
                        <!-- Column 1: Logo -->
                        {
                            resolvedImage && (
                                <div class="flex-shrink-0 mx-auto md:mx-0">
                                    <div class="w-20 h-20 sm:w-24 sm:h-24 overflow-hidden">
                                        <Image
                                            class="w-full h-full object-contain"
                                            src={resolvedImage}
                                            alt={title}
                                            loading="eager"
                                            format="webp"
                                            width={96}
                                            height={96}
                                        />
                                    </div>
                                </div>
                            )
                        }

                        <!-- Column 2: Title, Author, Categories -->
                        <div class="min-w-0 flex flex-col gap-2">
                            <h1
                                class="text-xl sm:text-2xl lg:text-3xl font-bold tracking-tight leading-tight line-clamp-2 text-gray-900 dark:text-gray-100"
                            >
                                {title}
                            </h1>
                            {
                                primaryAuthor && (
                                    <div class="text-sm sm:text-base text-gray-600 dark:text-gray-400">
                                        <span class="text-gray-500 dark:text-gray-500">by </span>
                                        <a
                                            href={authorLink}
                                            class="text-primary-600 dark:text-primary-400 hover:underline font-medium"
                                        >
                                            {primaryAuthor.data.name}
                                        </a>
                                    </div>
                                )
                            }

                            <!-- Category chips (max 2) -->
                            {
                                categories.length > 0 && (
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        {categories.slice(0, 2).map((category) => (
                                            <a
                                                href={`/categories/${category}`}
                                                class="px-3 py-1 rounded-full text-xs sm:text-sm font-medium bg-gray-100 dark:bg-secondary-800 text-gray-700 dark:text-gray-300 hover:bg-gray-200 dark:hover:bg-secondary-700 transition-colors"
                                            >
                                                {formatCategoryName(category)}
                                            </a>
                                        ))}
                                    </div>
                                )
                            }

                            <!-- Tags (scrollable on mobile) -->
                            {
                                tags && tags.length > 0 && (
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        {tags.slice(0, 8).map((tag) => (
                                            <a
                                                href={`/tags/${tag}`}
                                                class="text-xs px-2.5 py-1 rounded-full bg-primary-100 dark:bg-primary-900/50 text-primary-700 dark:text-primary-300 hover:bg-primary-200 dark:hover:bg-primary-800 transition-colors whitespace-nowrap"
                                            >
                                                #{tag}
                                            </a>
                                        ))}
                                        {tags.length > 8 && (
                                            <span class="text-xs py-1 text-gray-500 dark:text-gray-400">
                                                +{tags.length - 8} more
                                            </span>
                                        )}
                                    </div>
                                )
                            }
                        </div>

                        <!-- Column 3: Primary CTA (desktop only on same row, mobile below) -->
                        <div
                            class="flex-shrink-0 flex items-start justify-center md:justify-start lg:items-start mt-4 md:mt-0 lg:mt-0"
                        >
                            {
                                primaryCTALabel && primaryCTAUrl && (
                                    <div class="relative">
                                        <a
                                            href={primaryCTAUrl}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="inline-flex items-center justify-center px-5 py-2.5 sm:px-6 sm:py-3 text-sm sm:text-base font-semibold rounded-xl transition-colors w-full sm:w-auto bg-primary-600 hover:bg-primary-700 text-white dark:bg-primary-500 dark:hover:bg-primary-400 shadow-md hover:shadow-lg"
                                            data-cta-dropdown
                                        >
                                            {primaryCTALabel}
                                            {ctaGroups.length > 0 &&
                                            ctaGroups.reduce(
                                                (total, group) => total + group.links.length,
                                                0
                                            ) > 1 ? (
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    class="w-4 h-4 ml-2"
                                                    fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M19 9l-7 7-7-7"
                                                    />
                                                </svg>
                                            ) : (
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    class="w-4 h-4 ml-2"
                                                    fill="none"
                                                    viewBox="0 0 24 24"
                                                    stroke="currentColor"
                                                >
                                                    <path
                                                        stroke-linecap="round"
                                                        stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                                                    />
                                                </svg>
                                            )}
                                        </a>
                                        {/* Dropdown Popup */}
                                        {ctaGroups.length > 0 &&
                                            ctaGroups.reduce(
                                                (total, group) => total + group.links.length,
                                                0
                                            ) > 1 && (
                                                <div
                                                    class="absolute left-0 right-0 sm:left-auto sm:right-0 z-50 mt-2 w-64 p-3 bg-white dark:bg-secondary-900 rounded-xl shadow-xl border border-gray-200 dark:border-gray-700 hidden cta-dropdown"
                                                    data-cta-menu
                                                >
                                                    <div class="flex flex-col gap-3">
                                                        {ctaGroups.map((group) => (
                                                            <div>
                                                                <div class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-2">
                                                                    {group.label}
                                                                </div>
                                                                <div class="flex flex-col gap-1">
                                                                    {group.links.map((link) => {
                                                                        const isPlayStore =
                                                                            link.label
                                                                                .toLowerCase()
                                                                                .includes(
                                                                                    'play store'
                                                                                ) ||
                                                                            link.url.includes(
                                                                                'play.google.com'
                                                                            );
                                                                        const isAppStore =
                                                                            link.label
                                                                                .toLowerCase()
                                                                                .includes(
                                                                                    'app store'
                                                                                ) ||
                                                                            link.url.includes(
                                                                                'apps.apple.com'
                                                                            );
                                                                        const isFdroidStore =
                                                                            link.label
                                                                                .toLowerCase()
                                                                                .includes(
                                                                                    'fdroid'
                                                                                ) ||
                                                                            link.url.includes(
                                                                                'f-droid.org'
                                                                            );
                                                                        const isGithub =
                                                                            link.label
                                                                                .toLowerCase()
                                                                                .includes(
                                                                                    'github'
                                                                                ) ||
                                                                            link.url.includes(
                                                                                'github.com'
                                                                            );
                                                                        return (
                                                                            <a
                                                                                href={link.url}
                                                                                target="_blank"
                                                                                rel="noopener noreferrer"
                                                                                class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
                                                                            >
                                                                                {isPlayStore ? (
                                                                                    <Image
                                                                                        src={
                                                                                            googlePlayBadge
                                                                                        }
                                                                                        alt={
                                                                                            link.label
                                                                                        }
                                                                                        class="h-8 w-auto"
                                                                                        format="webp"
                                                                                        loading="lazy"
                                                                                    />
                                                                                ) : isFdroidStore ? (
                                                                                    <Image
                                                                                        src={
                                                                                            fdroidBadge
                                                                                        }
                                                                                        alt={
                                                                                            link.label
                                                                                        }
                                                                                        class="h-8 w-auto"
                                                                                        format="webp"
                                                                                        loading="lazy"
                                                                                    />
                                                                                ) : isAppStore ? (
                                                                                    <Image
                                                                                        src={
                                                                                            appStoreBadge
                                                                                        }
                                                                                        alt={
                                                                                            link.label
                                                                                        }
                                                                                        class="h-8 w-auto"
                                                                                        format="webp"
                                                                                        loading="lazy"
                                                                                    />
                                                                                ) : isGithub ? (
                                                                                    <Image
                                                                                        src={
                                                                                            githubBadge
                                                                                        }
                                                                                        alt={
                                                                                            link.label
                                                                                        }
                                                                                        class="h-8 w-auto"
                                                                                        format="webp"
                                                                                        loading="lazy"
                                                                                    />
                                                                                ) : (
                                                                                    <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                                                                                        {link.label}
                                                                                    </span>
                                                                                )}
                                                                            </a>
                                                                        );
                                                                    })}
                                                                </div>
                                                            </div>
                                                        ))}
                                                    </div>
                                                </div>
                                            )}
                                    </div>
                                )
                            }
                        </div>
                    </div>

                    <!-- Badges row - below the main content on all screen sizes -->
                    <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-700">
                        <div class="flex flex-wrap gap-2 sm:gap-3">
                            {/* Free/Paid badge */}
                            <span
                                class={`px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium whitespace-nowrap ${
                                    paid
                                        ? 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300'
                                        : 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300'
                                }`}
                            >
                                {paid ? 'Paid' : 'Free'}
                            </span>
                            {/* Ads badge */}
                            <span
                                class={`px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium whitespace-nowrap ${
                                    ads
                                        ? 'bg-red-100 dark:bg-red-900/40 text-red-700 dark:text-red-300'
                                        : 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300'
                                }`}
                            >
                                {ads ? 'Has Ads' : 'No Ads'}
                            </span>
                            {/* Source badge */}
                            <span
                                class={`px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium whitespace-nowrap ${
                                    source === 'open-source'
                                        ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300'
                                        : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
                                }`}
                            >
                                {source === 'open-source' ? 'Open Source' : 'Closed Source'}
                            </span>
                            {/* Offline badge */}
                            <span
                                class={`px-3 py-1.5 rounded-full text-xs sm:text-sm font-medium whitespace-nowrap ${
                                    offline
                                        ? 'bg-green-100 dark:bg-green-900/40 text-green-700 dark:text-green-300'
                                        : 'bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-400'
                                }`}
                            >
                                {offline ? 'Works Offline' : 'Needs Internet'}
                            </span>
                        </div>
                    </div>
                </div>
            </header>

            <!-- Description -->
            <div class="mt-10 mb-6 px-4 sm:px-4 lg:px-0">
                <p
                    class="text-base sm:text-lg text-gray-700 dark:text-gray-300 leading-relaxed max-w-none"
                >
                    {description}
                </p>
            </div>

            <!-- Engagement -->
            <Engage
                repositoryLinks={repositoryLinks}
                source={source}
                socials={socials}
                website={website}
            />

            <!-- Screenshots -->
            {screenshots && <Screenshots screenshots={screenshots} />}

            <!-- Youtube Links -->
            {
                ((youtubeVideoIds && youtubeVideoIds.length > 0) ||
                    (youtubeShortsIds && youtubeShortsIds.length > 0)) && (
                    <YouTubeEmbed
                        youtubeVideoIds={youtubeVideoIds}
                        youtubeShortsIds={youtubeShortsIds}
                    />
                )
            }

            <!-- Features -->
            <div class="prose prose-lg dark:prose-dark max-w-none mb-2">
                <slot />
            </div>

            <!-- Store badges -->
            <StoreBadges storeLinks={storeLinks} />

            <!-- Additional resources -->
            {
                externalLinks && externalLinks.length > 0 && (
                    <footer class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-800">
                        <div class="mb-6">
                            <h3 class="text-xl font-semibold mb-3">External Resources</h3>
                            <ul class="space-y-2">
                                {externalLinks.map((link) => (
                                    <li>
                                        <a
                                            href={link.url}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="text-primary-600 dark:text-primary-400 hover:underline"
                                        >
                                            {link.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </footer>
                )
            }
        </article>

        <RightSidebar>
            <slot name="right-sidebar" />
        </RightSidebar>
    </div>

    <script>
        // CTA Dropdown functionality
        document.addEventListener('DOMContentLoaded', () => {
            const triggers = document.querySelectorAll<HTMLAnchorElement>('[data-cta-dropdown]');

            triggers.forEach((trigger) => {
                trigger.addEventListener('click', (e) => {
                    const menu = trigger.nextElementSibling as HTMLElement | null;
                    if (menu && menu.classList.contains('cta-dropdown')) {
                        e.preventDefault();
                        menu.classList.toggle('hidden');
                    }
                });
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', (e) => {
                const target = e.target as HTMLElement;
                if (!target.closest('[data-cta-dropdown]') && !target.closest('.cta-dropdown')) {
                    document.querySelectorAll<HTMLElement>('.cta-dropdown').forEach((menu) => {
                        menu.classList.add('hidden');
                    });
                }
            });
        });
    </script>
</BaseLayout>
